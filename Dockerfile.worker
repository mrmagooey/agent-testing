# ---------------------------------------------------------------------------
# Build stage: compile gopls from source using the Go toolchain.
# The Go toolchain is NOT carried into the final image — only the binary.
# ---------------------------------------------------------------------------
FROM golang:1.24-alpine AS gopls-builder
RUN go install golang.org/x/tools/gopls@v0.16.2

FROM python:3.14-slim

WORKDIR /app

# ---------------------------------------------------------------------------
# System toolchain dependencies
#
# Base packages required by:
#   - tree-sitter C extensions (gcc, g++, make)
#   - clangd LSP server (clangd)
#   - pyright + typescript-language-server (nodejs, npm)
#   - gopls: installed from a pre-compiled release binary (no Go toolchain needed)
#   - rust-analyzer: installed from a pre-compiled release binary
#
# Estimated additional image size from LSP tooling: ~400-600 MB
#   nodejs + npm:              ~120 MB
#   pyright (npm global):       ~90 MB
#   typescript-language-server: ~30 MB
#   typescript:                 ~30 MB
#   clangd:                     ~50 MB
#   gopls binary:               ~30 MB
#   rust-analyzer binary:       ~80 MB
# ---------------------------------------------------------------------------
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      gcc g++ make \
      clangd \
      nodejs npm \
      curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# npm-based LSP servers: pyright, typescript-language-server, typescript.
# Versions pinned for reproducibility — bump deliberately.
# ---------------------------------------------------------------------------
ARG PYRIGHT_VERSION=1.1.409
ARG TS_LANGUAGE_SERVER_VERSION=5.1.3
ARG TYPESCRIPT_VERSION=6.0.3
RUN npm install -g --no-audit --no-fund \
      pyright@${PYRIGHT_VERSION} \
      typescript-language-server@${TS_LANGUAGE_SERVER_VERSION} \
      typescript@${TYPESCRIPT_VERSION} \
 && npm cache clean --force

# ---------------------------------------------------------------------------
# gopls — copied from the gopls-builder stage (compiled from source).
# The Go toolchain stays in the build stage; only the ~30 MB binary ships here.
# To upgrade: change the version in the gopls-builder stage above.
# ---------------------------------------------------------------------------
COPY --from=gopls-builder /go/bin/gopls /usr/local/bin/gopls

# ---------------------------------------------------------------------------
# rust-analyzer — pre-compiled binary (single static binary, no Rust toolchain).
# Pin to a specific release tag; update SHA-256 when upgrading.
# ---------------------------------------------------------------------------
ARG RUST_ANALYZER_VERSION=2024-10-28
ARG RUST_ANALYZER_SHA256=9c62085e707352ba9459bfe5ebaac5f68c084b067167679077644ec108474baa
RUN curl -fsSL \
      "https://github.com/rust-lang/rust-analyzer/releases/download/${RUST_ANALYZER_VERSION}/rust-analyzer-x86_64-unknown-linux-gnu.gz" \
      -o /tmp/rust-analyzer.gz \
 && echo "${RUST_ANALYZER_SHA256}  /tmp/rust-analyzer.gz" | sha256sum -c - \
 && gunzip -c /tmp/rust-analyzer.gz > /usr/local/bin/rust-analyzer \
 && chmod +x /usr/local/bin/rust-analyzer \
 && rm /tmp/rust-analyzer.gz

# ---------------------------------------------------------------------------
# semgrep — installed via pipx to isolate its mcp/opentelemetry-api deps from
# the worker venv (semgrep pins mcp<2 which conflicts with pydantic-ai's mcp>=1).
# The pipx venv lives at /root/.local/pipx/venvs/semgrep; the binary is
# symlinked to /root/.local/bin/semgrep which is added to PATH below.
# ---------------------------------------------------------------------------
ARG SEMGREP_VERSION=1.113.0
RUN pip install --no-cache-dir pipx \
 && pipx install "semgrep==${SEMGREP_VERSION}" \
 && /root/.local/bin/semgrep --version

ENV PATH="/root/.local/bin:${PATH}"

# Verify the binary is reachable on PATH after the ENV update.
RUN semgrep --version

# Install framework with worker extras against a stub source tree so this
# heavy layer (tree-sitter deps) is cached unless pyproject.toml changes.
COPY pyproject.toml .
RUN mkdir -p src/sec_review_framework \
 && touch src/sec_review_framework/__init__.py \
 && pip install --no-cache-dir ".[worker,agent]" \
 && rm -rf src

# Pre-download tree-sitter grammars for offline use at runtime.
# Target language set for security review:
#   python, javascript, typescript, tsx, go, java, ruby, rust,
#   c, cpp, php, bash, yaml, json, hcl, dockerfile, sql
# tree-sitter-language-pack downloads per-language .so files on first use;
# running init() here bakes them into the image layer so workers are fully offline.
RUN python - <<'EOF'
try:
    from tree_sitter_language_pack import init
    init([
        "python", "javascript", "typescript", "tsx",
        "go", "java", "ruby", "rust",
        "c", "cpp", "php", "bash",
        "yaml", "json", "hcl", "dockerfile", "sql",
    ])
    print("tree-sitter grammars pre-downloaded OK")
except Exception as e:
    # Non-fatal during build — grammars will be downloaded on first worker use.
    print(f"WARNING: grammar pre-download failed: {e}")
EOF

# Copy real sources last — changes here only invalidate the fast no-deps reinstall.
COPY src/ src/
RUN pip install --no-cache-dir --no-deps --force-reinstall .

ENTRYPOINT ["python", "-m", "sec_review_framework.worker"]
