FROM python:3.14-slim

# Install git for CVE repo cloning
RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*

# Install dependencies against a stub source tree so this layer is cached
# unless pyproject.toml changes.
COPY pyproject.toml .
RUN mkdir -p src/sec_review_framework \
 && touch src/sec_review_framework/__init__.py \
 && pip install --no-cache-dir . \
 && rm -rf src

# Copy real sources last — only invalidates the fast no-deps reinstall below.
COPY src/ src/
RUN pip install --no-cache-dir --no-deps --force-reinstall .

# ---------------------------------------------------------------------------
# Note on DevDocs docset sync
#
# The devdocs_sync module (sec_review_framework.data.devdocs_sync) is NOT run
# here at image build time. Docsets are downloaded at Job execution time onto
# the shared PVC so they are available to all worker pods without being baked
# into the image layer.
#
# The devdocs-sync Helm Job (helm/sec-review/templates/devdocs-sync-job.yaml)
# runs this command on post-install / post-upgrade:
#
#   python -m sec_review_framework.data.devdocs_sync \
#       --root /data/devdocs \
#       --docsets python~3.12,javascript,typescript,...
#
# Subsequent runs are idempotent (files already present are skipped unless
# --force is passed).
# ---------------------------------------------------------------------------

ENTRYPOINT ["python", "-m", "sec_review_framework.ground_truth.cve_importer"]
